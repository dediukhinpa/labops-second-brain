# public-second_brain-agentos — environment variable template
#
# Copy this to `.env` on each host (VPS and local workstation) and fill in the
# values that apply to that host. Most values are auto-filled by the install
# scripts; only the optional skill API keys and the BotFather token are user-
# supplied.
#
# NEVER commit a populated `.env` file. The `.gitignore` excludes it.
# Always `chmod 600 .env` after writing.
#
# Iter 2 — ignore-marker syntax for the env-sync checker:
#   Prefix a documented-but-unreferenced var with a comment line
#       # check_env_sync: ignore -- <reason>
#   to suppress the "documented but never referenced in code" warning.
#   Use sparingly: only for vars consumed by transitive dependencies or
#   non-scanned files (markdown docs, Caddyfile templates, etc.).

# =============================================================================
# Postgres (VPS only)
# =============================================================================

# Optional full Postgres DSN (e.g. postgres://user:pass@host:5432/db). When set,
# scripts that support it (e.g. scripts/issue-hmac-secret.py) use this DSN
# directly and ignore PG_HOST/PG_PORT/PG_USER/PG_DATABASE/PG_PASSWORD.
# Leave empty to compose the connection from the discrete PG_* vars below.
# check_env_sync: ignore -- override path used only by issue-hmac-secret.py; primary path is PG_* discrete vars
SECOND_BRAIN_DB_DSN=

# Hostname Postgres listens on. Default: /var/run/postgresql (unix socket,
# peer auth, no password needed). Set to 127.0.0.1 for TCP loopback with
# password auth, or to a remote host for managed Postgres.
PG_HOST=/var/run/postgresql

# Postgres port. Default: 5432.
PG_PORT=5432

# Database name. Created by install.sh.
PG_DATABASE=second_brain

# Postgres role used by all services. Created by install.sh with a generated
# password.
PG_USER=second_brain

# Generated by install.sh and printed once. Captured by the install agent.
PG_PASSWORD=<generated-during-install>

# =============================================================================
# MCP services (VPS only)
# =============================================================================

# Bind address. Keep 127.0.0.1 if Caddy is in front (recommended).
# Use 0.0.0.0 only behind a firewall (UFW + Tailscale) where you understand
# the exposure.
MCP_HOST=127.0.0.1

# Ports for each service. Defaults match Caddyfile.template.
MCP_MEMORY_PORT=8767
MCP_RECALL_PORT=8768
MCP_SWARM_PORT=8766
# check_env_sync: ignore -- consumed by Caddyfile.template + unit files, not scanned code (task-board client reads TASK_MCP_PORT)
MCP_TASK_PORT=8769

# Per-service port read by the in-process Config. Each service (memory/recall/
# swarm/task) starts with MCP_PORT set to its respective service port at unit-file
# level. Workers that do not bind an MCP listener set MCP_PORT=0 internally.
MCP_PORT=8767

# Filesystem root for the vault. install.sh creates this and copies the
# vault-template into it on first run.
VAULT_ROOT=/opt/second_brain/vault

# Path to per-service log directory. install.sh creates this owned by the
# `second_brain` system user.
LOG_DIR=/var/log/second_brain

# Tool-surface gating across memory/recall/swarm/task MCPs. One of: core, all.
#   core (default) -- exposes recall/get/related/recent;
#                     create_decision_note/create_handoff/append_daily_log/
#                     supersede_decision; swarm notify/ack;
#                     all 13 task tools (task_create/get/list/update/start/
#                     review/done/block/reopen/history + agent_heartbeat/
#                     status/list).
#   all            -- exposes the full surface including slots, stats,
#                     reindex_check, broadcast, escalate, get_delivery,
#                     list_recent_deliveries, list_my_pending.
# Invalid values fail-fast at service startup.
SECOND_BRAIN_TOOLS=core

# =============================================================================
# Retrieval tuning (VPS only, recall_mcp)
# =============================================================================

# Weight applied to BM25/FTS rank stream in RRF fusion. Re-normalized with
# SECOND_BRAIN_RRF_WEIGHT_VEC across present streams.
SECOND_BRAIN_RRF_WEIGHT_BM25=0.4

# Weight applied to dense vector rank stream in RRF fusion.
SECOND_BRAIN_RRF_WEIGHT_VEC=0.6

# Max results per scope before fill-back. 0 disables diversification and
# preserves pure score order. Recommended opt-in value: 3.
SECOND_BRAIN_DIVERSIFY_MAX=0

# Auto-supersession for create_decision_note: when the new decision's token
# set has Jaccard similarity >= this threshold against an existing live
# decision in the same scope, the old decision is flipped to is_latest=false
# + superseded_by:<new_path> inside a single DB transaction with the new
# insert. Set to 0 to disable auto-supersession entirely (hints still
# surface in the [SECOND_BRAIN_SUPERSEDE_HINT, SECOND_BRAIN_SUPERSEDE_AUTO) band).
# Must be <= 1.0; must be >= SECOND_BRAIN_SUPERSEDE_HINT.
SECOND_BRAIN_SUPERSEDE_AUTO=0.85

# Hint band lower bound: when SECOND_BRAIN_SUPERSEDE_HINT <= Jaccard <
# SECOND_BRAIN_SUPERSEDE_AUTO, the new decision is inserted unchanged and the
# return value carries a `suggested_supersedes` list for operator review --
# no DB mutation. Must be <= SECOND_BRAIN_SUPERSEDE_AUTO.
SECOND_BRAIN_SUPERSEDE_HINT=0.70

# -----------------------------------------------------------------------------
# Cross-encoder reranker (recall_mcp). SECOND_BRAIN_RERANK_ENABLED is the master
# switch; these tune it when enabled.
# -----------------------------------------------------------------------------
# Reranker model (FastEmbed TextCrossEncoder). Default: jina-reranker-v2.
SECOND_BRAIN_RERANK_MODEL=jinaai/jina-reranker-v2-base-multilingual
# How many top hybrid candidates to rerank (1..200). Default: 12.
SECOND_BRAIN_RERANK_CANDIDATES=12
# Per-candidate text cap in chars (64..8192) — bounds cross-encoder peak RSS. Default: 512.
SECOND_BRAIN_RERANK_MAX_CHARS=512
# ONNX weights within the model repo. int8 fits under MemoryMax. Default: onnx/model_int8.onnx.
SECOND_BRAIN_RERANK_ONNX_FILE=onnx/model_int8.onnx
# TextCrossEncoder ignores the standard cache var and defaults to /tmp
# (non-persistent); pin a dir to avoid re-downloading the reranker each start.
FASTEMBED_CACHE_DIR=

# =============================================================================
# Task supervisor (VPS only, task_mcp)
# =============================================================================
# Background reaper that reclaims stale in-progress tasks. Off by default;
# exactly one process (the launcher unit) sets this to 1.
SECOND_BRAIN_TASK_SUPERVISOR=0
# Supervisor sweep interval, seconds. Default: 60.
SECOND_BRAIN_TASK_SUPERVISOR_INTERVAL=60
# A task with no heartbeat for this long is considered stale, seconds. Default: 180.
SECOND_BRAIN_TASK_STALE_SECONDS=180
# Grace after stale before reclaim, seconds. Default: 90.
SECOND_BRAIN_TASK_GRACE_SECONDS=90

# =============================================================================
# Auth (VPS only)
# =============================================================================

# Admin agent token, printed once by install.sh on first run.
# Used by `scripts/issue-agent-token.py` to mint additional tokens.
# Treat as a root credential.
# check_env_sync: ignore -- read by scripts/issue-agent-token.py via argv/prompt, not os.environ; documented in docs/setup.md
ADMIN_AGENT_TOKEN=<printed-once-on-install>

# Salt for token sha256 storage. install.sh generates this. Do not change it
# after deployment — existing tokens would be invalidated.
TOKEN_HASH_SALT=<generated-during-install>

# -----------------------------------------------------------------------------
# Hermes-compatible HMAC auth (opt-in per agent)
# -----------------------------------------------------------------------------
# Set `hmac_secret_sha256` on an agent_tokens row via
# `scripts/issue-hmac-secret.py --agent <name>` to enable HMAC for that agent.
# Bearer remains active in parallel. See docs/hermes-integration.md.

# Master switch for inbound HMAC verification. Bearer auth is unaffected.
# Set to 0 to disable HMAC server-side without dropping the DB column.
# check_env_sync: ignore -- consumed by services/shared/config.py (set A); set C documents the knob ahead of A's middleware integration
SECOND_BRAIN_HMAC_AUTH_ENABLED=1

# Allowed skew between X-Hermes-Timestamp and server clock, in seconds.
# Hermes default is 300 (5 min). Lower = stricter; higher = more replay tolerance.
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300

# JSON object mapping agent name → raw HMAC secret. The raw secret is NEVER
# stored in Postgres; only sha256(raw) lives in agent_tokens. Empty `{}` means
# no HMAC agents are configured on this host.
# Example: SECOND_BRAIN_HMAC_SECRETS_JSON={"iris":"<raw_secret_from_issue_script>"}
SECOND_BRAIN_HMAC_SECRETS_JSON={}

# =============================================================================
# Swarm worker (VPS only, services/swarm_mcp/worker.py)
# =============================================================================

# Numeric Telegram chat id used as the destination for forwarded swarm prompts.
# Set to your owner/boss id. 0 disables forwarding.
OWNER_CHAT_ID=0

# Bearer token if the downstream chat gateway enforces auth. Empty = no header.
GATEWAY_WEBHOOK_TOKEN=

# Agent name used as the loop-prevention sink: tasks targeting this agent are
# ack-only and never re-forwarded.
COORDINATOR_AGENT=coordinator-agent

# JSON map of agent_name → gateway URL, e.g.
#   {"claude":"http://127.0.0.1:8089","vega":"http://127.0.0.1:8089","iris":"http://gateway.example/agent"}
# Used by the swarm worker to fan out forwarded prompts.
AGENT_GATEWAYS={}

# JSON map of agent_name → outbound auth spec, used by the swarm worker when
# delivering webhooks. Each value is a string of the form:
#   "bearer:env:NAME" — load raw Bearer token from env var NAME
#   "hmac:env:NAME"   — load raw HMAC secret from env var NAME (sign body)
#   "none"            — explicit no-auth (matches default)
# Missing entries fall back to the global GATEWAY_WEBHOOK_TOKEN Bearer if set.
# Example: AGENT_GATEWAY_AUTH={"iris":"hmac:env:iris_WEBHOOK_HMAC","claude":"bearer:env:GATEWAY_WEBHOOK_TOKEN"}
# check_env_sync: ignore -- consumed by services.swarm_mcp.worker._load_gateway_auth (set C did not modify worker.py)
AGENT_GATEWAY_AUTH={}

# Master switch for outbound HMAC signing in the swarm worker. When 0 the
# worker refuses to sign hmac-mode targets and returns them for retry.
SECOND_BRAIN_HMAC_OUTBOUND_ENABLED=1

# =============================================================================
# Ingest worker (VPS only)
# =============================================================================

# FastEmbed model. Pinned to multilingual-e5-large (1024 dims). Changing this
# requires re-embedding the entire vault.
FASTEMBED_MODEL=intfloat/multilingual-e5-large

# =============================================================================
# Inbox-agent (local workstation only)
# =============================================================================

# Root directory for the inbox-agent. Default written by install-local.sh.
INBOX_AGENT_HOME=~/.claude-lab/inbox-agent

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=<paste-from-botfather>

# Your numeric Telegram user_id. The bot ignores messages from anyone not in
# the allowlist (configured separately in classifier.yaml).
# check_env_sync: ignore -- referenced in docs/security.md; classifier.yaml allowlist binding
TELEGRAM_USER_ID=<your-user-id>

# Numeric Telegram user_id allowlist for inbox-agent's bot.py. Forwarded
# messages from any other id are dropped.
BOSS_CHAT_ID=<your-user-id>

# Path to the file containing the Telegram bot token. Defaults to
# $INBOX_AGENT_HOME/secrets/telegram-bot-token if unset.
TG_BOT_TOKEN_FILE=

# =============================================================================
# Optional skill API keys (local workstation only)
# =============================================================================
# Only set the ones you actually use. The inbox-agent classifier will skip any
# skill whose key is unset.

# Groq — Whisper transcription for voice notes.
# https://console.groq.com
GROQ_API_KEY=

# HikerAPI — Instagram caption + metadata extraction.
# https://hikerapi.com
# check_env_sync: ignore -- consumed by skills/instagram-superpower scripts that read from ~/.secrets/hikerapi/api-key
HIKERAPI_KEY=

# TranscriptAPI — YouTube transcripts.
# https://www.transcriptapi.com
# check_env_sync: ignore -- consumed by skills/transcript helpers via secret file fallback
TRANSCRIPTAPI_KEY=

# SocialData — X/Twitter thread reading.
# https://socialdata.tools
# check_env_sync: ignore -- consumed by skills/twitter helpers via secret file fallback
SOCIALDATA_KEY=

# Perplexity — web research via Sonar models.
# https://www.perplexity.ai/settings/api
# check_env_sync: ignore -- consumed by skills/perplexity-research helpers via secret file fallback
PERPLEXITY_API_KEY=

# =============================================================================
# Observability (optional, both hosts)
# =============================================================================

# Log level for services. One of: DEBUG, INFO, WARNING, ERROR.
# check_env_sync: ignore -- transitive dep (uvicorn/FastMCP log level)
LOG_LEVEL=INFO

# =============================================================================
# Install-time knobs (scripts/install.sh — VPS bootstrap)
# =============================================================================
# All of the following have sensible defaults inside scripts/install.sh
# (set via the `${VAR:=default}` idiom). You only need to set them in `.env`
# if you want to override the default. Listed here for discoverability.

# Root install directory for the second_brain server distribution.
INSTALL_DIR=/opt/second_brain

# Unix user that owns the install and runs the systemd units.
SERVICE_USER=second_brain

# Configuration directory (Caddy + systemd drop-ins).
ETC_DIR=/etc/second_brain

# Per-service state directory (lockfiles, watermark caches).
STATE_DIR=/var/lib/second_brain

# Public domain pointed at the VPS. If unset, Caddy is skipped and the
# services stay Tailscale-only.
DOMAIN=

# Email address for Let's Encrypt ACME registration. Required iff DOMAIN
# is set.
ACME_EMAIL=

# Directory that holds Postgres migration SQL files.
MIGRATIONS_DIR=/opt/second_brain/migrations

# =============================================================================
# Install-time knobs (agent-template/install.sh — agent workspace bootstrap)
# =============================================================================
# Override via env to skip the interactive prompts. All optional.

# Human-readable agent name (used in CLAUDE.md and SOUL.md).
AGENT_NAME=

# Role label shown in CLAUDE.md (e.g. "Coder", "Researcher").
AGENT_ROLE=

# One-paragraph role description for CLAUDE.md.
AGENT_ROLE_DESCRIPTION=

# Comma-separated character traits for SOUL.md.
CHARACTER_TRAITS=

# Bearer token for the agent, issued by scripts/issue-agent-token.py.
AGENT_BEARER=

# Comma-separated MCP scopes for the agent's token.
AGENT_SCOPES=

# Primary Claude model (e.g. claude-sonnet-4-5-20250929).
PRIMARY_MODEL=

# Research model used by deep-research skill.
RESEARCH_MODEL=

# Max concurrent subagents the agent will spawn.
MAX_SUBAGENTS=5

# Monthly token-budget cap (USD) used by token-budget guard.
BUDGET_LIMIT=

# Default Claude commit message language (en|ru).
COMMIT_LANGUAGE=en

# Default natural language for prompts and reflections.
LANGUAGE=en

# Timezone used in daily-digest and reflection hooks.
TIMEZONE=UTC

# Operator's public name (shown in agent docs).
OPERATOR_NAME=

# Operator contact (URL or handle).
OPERATOR_ADDRESS=

# Operator GitHub username (used by GitHub MCP skill if installed).
GITHUB_USERNAME=

# Default daily-digest natural language.
SUMMARY_LANGUAGE=en

# How many precompact snapshots to retain.
KEEP_SNAPSHOTS=20

# Default `recall.recent` limit used by session-start hook.
RECALL_LIMIT=20

# Where to find the `claude` CLI binary (override if not on $PATH).
CLAUDE_BIN=claude

# Workspace directory passed to stop-hook / verbose logger.
AGENT_WORKSPACE=

# Agent id (lowercase slug derived from AGENT_NAME by default).
AGENT_ID=

# =============================================================================
# Inbox-agent / smoke / local install knobs
# =============================================================================

# Bearer token for the inbox-agent's second_brain client.
INBOX_BEARER=

# Admin token used by scripts/smoke-test.sh.
ADMIN_TOKEN=

# Base URL for the smoke-test target (default: http://127.0.0.1:8767).
MCP_BASE=http://127.0.0.1:8767

# Where the inbox-agent dual-write hook talks to the brain. Either:
#   https://<your-domain>            (with Caddy + TLS)
#   http://<VPS_IP>:8767             (Tailscale-only)
MCP_URL=

# =============================================================================
# Skill: groq-voice (skills/groq-voice)
# =============================================================================

# Override the directory checked for the Groq API key file.
# Default: $HOME/.claude-lab/shared/secrets
SHARED_SECRETS=

# =============================================================================
# Misc bash-script placeholders
# =============================================================================

# Captured URL when the inbox-agent classifier extracts a link from a
# forwarded message. Exported for downstream skills.
# check_env_sync: ignore -- transient runtime variable, not user-configurable
URL=

# =============================================================================
# Task-board CLI client (scripts/task-board-second_brain.sh — any host)
# =============================================================================
# Thin bash wrapper around the task MCP. Reads these to reach the server and
# authenticate; all optional with sensible defaults.

# Host the task MCP is reachable on. Default: 127.0.0.1 (Caddy/loopback).
TASK_MCP_HOST=127.0.0.1

# Port the task MCP listens on. Default: 8769 (matches MCP_TASK_PORT).
TASK_MCP_PORT=8769

# Bearer token for the task MCP. If empty, the wrapper falls back to reading
# ~/.secrets/second_brain-token. Treat as a credential.
SECOND_BRAIN_TOKEN=

# =============================================================================
# Skill: second_brain-doctor (skills/second_brain-doctor — agent workstation)
# =============================================================================
# All optional. The doctor auto-detects most values; set these only to
# override or to enable checks that need extra context.

# Origin host IP behind the MCP edge (Caddy/Cloudflare). Set so the doctor can
# verify the true origin in topology-aware checks. Unset = origin check skips.
SECOND_BRAIN_BACKEND_IP=

# GitHub owner/repo for the per-agent private-repo check. Owner defaults to the
# authenticated `gh api user` login; repo defaults to a slug derived from the
# agent id. Set to override.
SECOND_BRAIN_GITHUB_OWNER=
SECOND_BRAIN_GITHUB_REPO=

# Recall scope used by the recall.recent probe (a read needs a valid scope).
# Also settable via the --probe-scope flag. Unset = the recent probe skips.
SECOND_BRAIN_PROBE_SCOPE=

# =============================================================================
# Agent-template webhook listener (agent-template/scripts/webhook_listener.py)
# =============================================================================
# Inbound Hermes-style webhook receiver. All optional with defaults.

# Port the listener binds on (127.0.0.1 only). Default: 8091.
WEBHOOK_PORT=8091

# Allowed skew between the signed timestamp and server clock, in seconds.
# Default: 300 (matches Hermes).
HMAC_TOLERANCE_SECONDS=300

# Directory where validated inbound payloads are written. Default: ~/.hermes/inbox.
INBOX_DIR=~/.hermes/inbox

# Path to the file holding the inbound Bearer token. Unset = Bearer check off.
WEBHOOK_BEARER_FILE=

# Path to the file holding the inbound HMAC secret. Unset = HMAC check off.
WEBHOOK_HMAC_SECRET_FILE=

# --- scripts/verify.sh deploy-gate knobs (tooling overrides, NOT service env) ---
# Consumed only by scripts/verify.sh to point the health check at a non-standard
# layout or enable the optional authenticated MCP probe. Services never read
# these. Ignore-marked so they document the knobs without tripping drift checks.
# check_env_sync: ignore -- scripts/verify.sh only: install prefix
SB_HOME=/opt/second_brain
# check_env_sync: ignore -- scripts/verify.sh only: config dir
SB_ETC=/etc/second_brain
# check_env_sync: ignore -- scripts/verify.sh only: secrets path
SECRETS=/etc/second_brain/secrets.env
# check_env_sync: ignore -- scripts/verify.sh only: venv interpreter
VENV_PY=/opt/second_brain/.venv/bin/python
# check_env_sync: ignore -- scripts/verify.sh only: optional agent token for authenticated MCP probe
VERIFY_BEARER=
